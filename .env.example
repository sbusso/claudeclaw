# Runtime: 'sandbox' (default, OS-level isolation) or 'container' (Apple Container / Docker)
RUNTIME=sandbox

ASSISTANT_NAME=MotherClaw

# Authentication (one of these required)
# ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_CODE_OAUTH_TOKEN=sk-...

# Slack (optional — add via /add-slack)
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# Triage extension (optional)
TICKET_DEV_CHANNEL_JID=
GH_TOKEN=
